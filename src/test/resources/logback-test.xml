<configuration>
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} -- %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Suppress BRIG logging during tests — error-path tests produce
       expected ERROR stack traces that look alarming but are harmless. -->
  <logger name="brig" level="OFF" />

  <root level="WARN">
    <appender-ref ref="CONSOLE" />
  </root>
</configuration>
